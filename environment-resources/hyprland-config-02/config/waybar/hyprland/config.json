    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "idle_inhibitor",
        "pulseaudio",
        "network",
        "cpu",
        "temperature",
        "temperature#gpu",
        "memory",
        "custom/disk-usage",
        "custom/disk-02",
