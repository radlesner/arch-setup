    "custom/power": {
        "format": "´Çæ",
        "tooltip": false,
        "on-click": "poweroff",
        "interval": 0
    },
    "custom/reboot": {
        "format": "¯½Æ",
        "tooltip": false,
        "on-click": "reboot",
        "interval": 0
    },
    "custom/logout": {
        "format": "¾░┐à",
        "tooltip": false,
        "on-click": "hyprctl dispatch exit",
