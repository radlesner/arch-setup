    },
    "memory": {
        "format": "´âë {}%"
    },
    "custom/disk-usage": {
        "exec": "~/.config/waybar/scripts/disk-used.sh / ´îâ",
        "interval": 10,
        "tooltip": true
    },
    "custom/disk-01": {
        "exec": "~/.config/waybar/scripts/disk-used.sh /home/sp2cha/Games ¾░ëï",
        "interval": 10,
        "tooltip": true
    },
    "custom/disk-02": {
        "exec": "~/.config/waybar/scripts/disk-used.sh /home/sp2cha/Pictures ¾░ëÅ",
